# Database (Neon Postgres)
# Use the pooled host (-pooler) for the runtime; the unpooled host is for drizzle-kit.
DATABASE_URL="postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js v5
# Generate with: openssl rand -base64 32
# MUST be identical across production + preview (preview's signed state cookie is verified by prod).
AUTH_SECRET=""
# Local dev only — Vercel infers the URL on prod/preview when AUTH_TRUST_HOST=true.
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth — see PR for the Google Cloud Console walkthrough.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Local-dev-only sign-in bypass (UNN-185). Enables POST /api/dev/sign-in,
# which lets agents land a session cookie without going through Google. The
# route signs in as the user identified by this email and is gated by
# NODE_ENV != production AND host == localhost; do NOT set on Vercel.
DEV_AUTH_EMAIL=""

# Set on BOTH Production and Preview in Vercel (same value, pointing at the
# production URL). Forwards OAuth callbacks through prod so Google only sees
# one registered redirect URI. Auth.js detects proxy-mode by comparing the
# current request origin against this URL: previews swap their redirect_uri
# to the proxy and sign the origin into state; prod reads the state and 302s
# back to the preview origin. Without it set on prod, prod tries to validate
# PKCE against a cookie that lives on the preview hostname and 500s. Leave
# unset in local dev.
# AUTH_REDIRECT_PROXY_URL="https://<your-prod-domain>/api/auth"
