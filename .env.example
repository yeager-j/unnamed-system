# Database (Neon Postgres)
# Use the pooled host (-pooler) for the runtime; the unpooled host is for drizzle-kit.
DATABASE_URL="postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js v5
# Generate with: openssl rand -base64 32
# MUST be identical across production + preview (preview's signed state cookie is verified by prod).
AUTH_SECRET=""
# Local dev only — Vercel infers the URL on prod/preview when AUTH_TRUST_HOST=true.
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth — see PR for the Google Cloud Console walkthrough.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Preview-only on Vercel: forwards OAuth callbacks through production so Google
# only sees one registered redirect URI. Leave unset in dev and prod.
# AUTH_REDIRECT_PROXY_URL="https://<your-prod-domain>/api/auth"
