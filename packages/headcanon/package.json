{
  "name": "@workspace/headcanon",
  "version": "0.0.0",
  "description": "Optimistic mutations for Next.js: believe your writes until canon says otherwise.",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "eslint --fix \"**/*.{ts,mjs}\" && prettier --write \"**/*.{ts,mjs,md,json}\"",
    "typecheck": "tsc --noEmit",
    "depcheck": "node depcheck.mjs",
    "test": "vitest run"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./ably/channels": "./src/ably/channels.ts",
    "./ably/client": "./src/ably/client.ts",
    "./ably/server": "./src/ably/server.ts",
    "./drizzle": "./src/drizzle.ts",
    "./drizzle-schema": "./src/receipt-table.ts",
    "./next/client": "./src/next/client.ts",
    "./next/server": "./src/next/server.ts",
    "./react": "./src/react.ts",
    "./testing": "./src/testing.ts"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@workspace/result": "*",
    "canonicalize": "^3.0.0"
  },
  "peerDependencies": {
    "ably": "^2.22.1",
    "drizzle-orm": "^0.45.2",
    "next": "^16.1.6",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "ably": "^2.22.1",
    "eslint": "^9.39.2",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
