{
  "name": "@workspace/game-v2",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "eslint --fix \"**/*.ts\" && prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "depcheck": "node depcheck.mjs",
    "test": "vitest run --passWithNoTests",
    "test:contract": "vitest run --passWithNoTests src/**/__contract__",
    "test:integration": "vitest run --passWithNoTests src/**/__integration__",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:mutation": "stryker run"
  },
  "sideEffects": false,
  "exports": {
    "./kernel": "./src/kernel/index.ts",
    "./kernel/vocab": "./src/kernel/vocab/index.ts",
    "./kernel/*": "./src/kernel/*.ts",
    "./archetypes": "./src/archetypes/index.ts",
    "./archetypes/*": "./src/archetypes/*.ts",
    "./attributes": "./src/attributes/index.ts",
    "./attributes/*": "./src/attributes/*.ts",
    "./affinities": "./src/affinities/index.ts",
    "./affinities/*": "./src/affinities/*.ts",
    "./progression": "./src/progression/index.ts",
    "./progression/*": "./src/progression/*.ts",
    "./vitals": "./src/vitals/index.ts",
    "./vitals/*": "./src/vitals/*.ts",
    "./resources": "./src/resources/index.ts",
    "./resources/*": "./src/resources/*.ts",
    "./mechanics": "./src/mechanics/index.ts",
    "./mechanics/*": "./src/mechanics/*.ts",
    "./combat": "./src/combat/index.ts",
    "./combat/*": "./src/combat/*.ts",
    "./encounter": "./src/encounter/index.ts",
    "./encounter/*": "./src/encounter/*.ts",
    "./visibility": "./src/visibility/index.ts",
    "./visibility/*": "./src/visibility/*.ts",
    "./spatial": "./src/spatial/index.ts",
    "./spatial/*": "./src/spatial/*.ts",
    "./items": "./src/items/index.ts",
    "./items/*": "./src/items/*.ts",
    "./skills": "./src/skills/index.ts",
    "./skills/*": "./src/skills/*.ts",
    "./talents": "./src/talents/index.ts",
    "./talents/*": "./src/talents/*.ts",
    "./virtues": "./src/virtues/index.ts",
    "./virtues/*": "./src/virtues/*.ts",
    "./narrative": "./src/narrative/index.ts",
    "./narrative/*": "./src/narrative/*.ts",
    "./catalog": "./src/catalog/index.ts",
    "./catalog/*": "./src/catalog/*.ts",
    "./composition": "./src/composition.ts",
    "./resolve": "./src/resolve/index.ts",
    "./resolve/*": "./src/resolve/*.ts"
  },
  "dependencies": {
    "immer": "^11.1.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.1.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "eslint": "^9.39.2",
    "fast-check": "^4.9.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
