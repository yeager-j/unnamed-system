{
  "name": "@workspace/result",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "eslint --fix \"**/*.{ts,mjs}\" && prettier --write \"**/*.{ts,mjs,md,json}\"",
    "typecheck": "tsc --noEmit",
    "depcheck": "node depcheck.mjs",
    "test": "vitest run"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "devDependencies": {
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "eslint": "^9.39.2",
    "fast-check": "^4.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
