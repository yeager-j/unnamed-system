{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "AUTH_SECRET",
    "AUTH_URL",
    "AUTH_TRUST_HOST",
    "AUTH_REDIRECT_PROXY_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "DEV_AUTH_EMAIL",
    "BLOB_READ_WRITE_TOKEN",
    "NEXT_PUBLIC_INCLUDE_DEMO_ARCHETYPES",
    "ABLY_API_KEY",
    "VERCEL_ENV",
    "VERCEL_GIT_COMMIT_REF",
    "FC_SEED",
    "FC_NUM_RUNS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:e2e": {
      "cache": false,
      "env": ["BASE_URL", "CI", "VERCEL_AUTOMATION_BYPASS_SECRET"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
